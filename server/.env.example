# Runtime mode. Production enables strict boot validation and secure cookies.
NODE_ENV="production"
# HTTP listener port; optional, defaults to 4000.
PORT="4000"
# Release identifier returned by /healthz and attached to error reports.
# VERCEL_GIT_COMMIT_SHA is used automatically when APP_VERSION is omitted.
APP_VERSION="1.0.0"

# Required in every runtime. Use a dedicated application database credential.
DATABASE_URL="postgresql://vaka:CHANGE_ME@localhost:5432/vaka_platform"
# Required in every runtime. Production requires at least 64 random bytes.
JWT_SECRET="GENERATE_64_RANDOM_BYTES"
# Required in production. Comma-separated exact browser origins; wildcards and
# URL paths are rejected. Credentials are allowed only for these origins.
ALLOWED_ORIGINS="https://app.example.com"

# Required dedicated encryption keys; each must be at least 32 random bytes in
# production. They must not reuse or fall back to JWT signing material.
CAPTURE_ENCRYPTION_KEY="GENERATE_32_RANDOM_BYTES"
MFA_ENCRYPTION_KEY="GENERATE_32_RANDOM_BYTES"
PAYNOW_ENCRYPTION_KEY="GENERATE_32_RANDOM_BYTES"

# Public application/API origin used for expiring customer document and
# password-recovery links. Production requires this value or Vercel's managed
# VERCEL_PROJECT_PRODUCTION_URL. HTTPS is mandatory in production.
PUBLIC_APP_URL="https://app.example.com"
# Vercel supplies this automatically; document the alternative, do not invent
# or duplicate it when the platform already injects the value.
VERCEL_PROJECT_PRODUCTION_URL=""

# Transactional email. Production always sends through SMTP and rejects false
# or incomplete configuration. Development/staging default to console output
# unless SMTP_ENABLED=true; tests always use memory.
SMTP_ENABLED="true"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_AUTH_USER="smtp-user"
SMTP_AUTH_PASSWORD="CHANGE_ME"
SMTP_FROM_ADDRESS="notifications@example.com"
SMTP_FROM_NAME="VAKA"
SMTP_REPLY_TO="support@example.com"
# implicit = TLS from connection start; starttls = upgrade required; none is
# allowed only for explicitly-enabled local/staging SMTP test servers.
SMTP_TLS="starttls"

# Optional Sentry-compatible error ingest DSN. When blank, error tracking is a
# no-op; structured local logs and crash discipline remain active.
SENTRY_DSN=""

# Explicit production switch for VAKA subscription collection. When true, the
# merchant ID/key and supported currency are required; false keeps it disabled.
PAYNOW_ENABLED="false"
PAYNOW_INTEGRATION_ID=""
PAYNOW_INTEGRATION_KEY=""
PAYNOW_CURRENCY="USD"

# Required only when npm run seed is executed; minimum 16 bytes. It is not a
# server boot variable and must be stored separately from runtime credentials.
PLATFORM_ADMIN_PASSWORD="SET_STRONG_PASSWORD_BEFORE_SEED"
