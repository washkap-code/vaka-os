# Required in production. Local development otherwise uses the documented localhost database.
DATABASE_URL="postgresql://jonomi:CHANGE_ME@localhost:5432/jonomi_platform"
EMAIL_PROVIDER_URL="https://api.example-email-provider.com/send"
EMAIL_PROVIDER_TOKEN="CHANGE_ME"
EMAIL_FROM="notifications@example.com"
# Public application/API origin used for expiring customer document and
# password-recovery links. On Vercel, VERCEL_PROJECT_PRODUCTION_URL is the
# safe system fallback when this value is omitted.
PUBLIC_APP_URL="https://app.example.com"
# Required in production; generate at least 64 random bytes.
JWT_SECRET="GENERATE_64_RANDOM_BYTES"
# Recommended for capture evidence encryption; minimum 32 bytes in production.
# If omitted during the migration period, the JWT secret is used as a compatibility fallback.
CAPTURE_ENCRYPTION_KEY="GENERATE_32_RANDOM_BYTES"
# Required before enrolling production MFA factors; minimum 32 random bytes.
# Rotate only through a planned decrypt-and-re-encrypt migration.
MFA_ENCRYPTION_KEY="GENERATE_32_RANDOM_BYTES"
# Required whenever npm run seed is executed; minimum 16 bytes.
PLATFORM_ADMIN_PASSWORD="SET_STRONG_PASSWORD_BEFORE_SEED"
PORT=4000
NODE_ENV=production
