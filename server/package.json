{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "seed": "tsx src/seed.ts",
    "check:runtime-schema": "node scripts/check-runtime-schema.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --fileParallelism=false --testTimeout=15000",
    "test:db:guard": "node --import tsx tests/finance/test-db-guard.ts",
    "test:db:prepare": "npm run test:db:guard && drizzle-kit push --force && node --import tsx scripts/apply-finance-integrity-controls.ts && node --import tsx scripts/apply-procurement-integrity-controls.ts && node --import tsx src/seed.ts",
    "test:finance": "npm run test:db:guard && vitest run --fileParallelism=false tests/finance/*.test.ts",
    "test:ai-evaluation": "vitest run tests/ai-evaluation.test.ts tests/ai-evaluation-runner.test.ts tests/business-summary.contract.test.ts",
    "test:integration": "vitest run --fileParallelism=false tests/critical.test.ts tests/business-summary.test.ts",
    "ai:evaluate": "node --import tsx src/ai/evaluation/cli.ts",
    "db:push": "drizzle-kit push"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.2.2",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "type": "module"
}
